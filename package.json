{
  "name": "penny-pincher",
  "version": "0.1.8",
  "description": "Agent-friendly CLI for reading bank and investment data through Plaid.",
  "type": "module",
  "homepage": "https://penny-pincher-cli.vercel.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jayhack/penny-pincher.git"
  },
  "bugs": {
    "url": "https://github.com/jayhack/penny-pincher/issues"
  },
  "bin": {
    "penny-pincher": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.api.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "plaid",
    "banking",
    "investments",
    "cli",
    "agent",
    "finance"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "latest",
    "chalk": "latest",
    "commander": "latest",
    "dotenv": "latest",
    "express": "latest",
    "open": "latest",
    "plaid": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/express": "latest",
    "@types/node": "latest",
    "@vercel/node": "^5.8.2",
    "tsx": "latest",
    "typescript": "latest"
  }
}
