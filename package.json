{
  "name": "finclaw",
  "version": "0.1.0",
  "description": "Agent-friendly CLI for reading your bank data through Plaid.",
  "type": "module",
  "bin": {
    "finclaw": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "plaid",
    "banking",
    "cli",
    "agent",
    "finance"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "latest",
    "chalk": "latest",
    "commander": "latest",
    "dotenv": "latest",
    "express": "latest",
    "open": "latest",
    "plaid": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/express": "latest",
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
